<Window x:Class="WpfCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kalkulator WPF" Height="400" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtDisplay" Grid.Row="0" FontSize="36" TextAlignment="Right" 
                 Margin="0,0,0,10" IsReadOnly="True" Text="0" 
                 Background="White" BorderBrush="Gray" BorderThickness="2"/>

        <UniformGrid Grid.Row="1" Columns="4" Rows="6">
            <Button Content="%" Click="BtnPercent_Click" Background="LightGray" Margin="2"/>
            <Button Content="CE" Click="BtnClearEntry_Click" Background="LightCoral" Margin="2"/>
            <Button Content="C" Click="BtnClear_Click" Background="IndianRed" Foreground="White" FontWeight="Bold" Margin="2"/>
            <Button Content="1/x" Click="BtnSingleOp_Click" Background="LightGray" Margin="2"/>

            <Button Content="x²" Click="BtnSingleOp_Click" Background="LightGray" Margin="2"/>
            <Button Content="√" Click="BtnSingleOp_Click" Background="LightGray" Margin="2"/>
            <Button Content="Motyw" Click="BtnMotyw_Click" Background="LightBlue" Margin="2"/>
            <Button Content="/" Click="BtnOperation_Click" Background="LightGray" FontWeight="Bold" Margin="2"/>

            <Button Content="7" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="8" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="9" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="*" Click="BtnOperation_Click" Background="LightGray" FontWeight="Bold" Margin="2"/>

            <Button Content="4" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="5" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="6" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="-" Click="BtnOperation_Click" Background="LightGray" FontWeight="Bold" Margin="2"/>

            <Button Content="1" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="2" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="3" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="+" Click="BtnOperation_Click" Background="LightGray" FontWeight="Bold" Margin="2"/>

            <Button Content="+/-" Click="BtnNegate_Click" Margin="2"/>
            <Button Content="0" Click="BtnDigit_Click" Margin="2"/>
            <Button Content="," Click="BtnDecimal_Click" Margin="2"/>
            <Button Content="=" Click="BtnEquals_Click" Background="MediumSeaGreen" Foreground="White" FontWeight="Bold" Margin="2"/>
        </UniformGrid>
    </Grid>
</Window>
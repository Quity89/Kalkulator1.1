<Window x:Class="Zadanie1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zadanie 1 - Layout" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="BoxStyle" TargetType="Border">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="SlateGray"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Border Style="{StaticResource BoxStyle}" Background="IndianRed"/>
                <Border Style="{StaticResource BoxStyle}" Background="Goldenrod"/>
                <Border Style="{StaticResource BoxStyle}" Background="SeaGreen"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Row="1" Grid.Column="0" 
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical" Margin="5">
                <Border Style="{StaticResource BoxStyle}" Background="SteelBlue"/>
                <Border Style="{StaticResource BoxStyle}" Background="MediumPurple"/>
                <Border Style="{StaticResource BoxStyle}" Background="DarkKhaki"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
                <Border Style="{StaticResource BoxStyle}"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" 
                Margin="5" Background="WhiteSmoke" BorderBrush="LightGray" BorderThickness="2">
            <TextBlock Text="Główny Content" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
        </Border>
    </Grid>
</Window>